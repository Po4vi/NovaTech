# Core API settings
PYTHON_VERSION=3.11.0

# IMAP inbox integration (required for email scanning)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USERNAME=your-email@example.com
EMAIL_IMAP_PASSWORD=your-app-password
EMAIL_IMAP_MAILBOX=INBOX

# Default scan behavior for /api/integrations/email/scan
EMAIL_SCAN_DEFAULT_LIMIT=10
EMAIL_SCAN_DEFAULT_UNREAD_ONLY=true

# Background auto polling (seconds). Set 0 to disable.
EMAIL_SCAN_POLL_SECONDS=0

# If true, polled emails are marked as \Seen to avoid rescanning same emails.
EMAIL_SCAN_POLL_MARK_AS_SEEN=true
